# Copy this file to the environment-specific files used by the new app.
# These names match the variables currently consumed by Spring Boot, Vite,
# and the local run/test workflow in this repository.

# Backend auth
JWT_SECRET=

# Backend datasource (used outside docker-compose; compose injects its own defaults)
DATABASE_URL=jdbc:postgresql://localhost:5432/readingrewards
DATABASE_USER=readingrewards
DATABASE_PASSWORD=readingrewards
JPA_DDL_AUTO=validate

# Email verification
BREVO_API_KEY=
SPRING_MAIL_FROM=noreply@example.com

# Frontend/backend URL alignment
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8080/api